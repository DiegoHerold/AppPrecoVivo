{
  "name": "fluxo-compras",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5174 -H 0.0.0.0",
    "dev:lan": "next dev -p 5174 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 5174 -H 0.0.0.0",
    "start:lan": "next start -p 5174 -H 0.0.0.0",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/lib/**/*.test.ts src/engine/**/*.test.ts src/domain/**/*.test.ts",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:verify": "tsx prisma/verify-schema.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:test-user": "node --conditions=react-server --import tsx prisma/seed-production-test-user.ts",
    "db:inference": "node --conditions=react-server --import tsx prisma/backfill-inference-events.ts",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && prisma migrate deploy && npm run db:verify && next build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@zxing/library": "^0.21.3",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
